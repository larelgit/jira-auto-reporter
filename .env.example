# ============================================
# Jira Auto-Reporter Configuration
# ============================================


# Atlassian Cloud Domain
JIRA_DOMAIN=your-workspace.atlassian.net

# Email Atlassian
JIRA_EMAIL=your-email@example.com

# API Token
JIRA_API_TOKEN=your-api-token-here

# Jira Project Key (e.g., UT, PROJ, BUG)
JIRA_PROJECT_KEY=UT

# Default Issue Type
JIRA_ISSUE_TYPE=Bug